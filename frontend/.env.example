# Backend API base URL (must include the version prefix)
VITE_API_URL=http://localhost:5000/api/v1

# Display name used across the UI
VITE_APP_NAME=Online Chasmewala

# Public storefront origin used for canonical URLs (set to the deployed HTTPS origin in production)
# VITE_SITE_URL=https://shop.example.com

# ── Feature flags (optional; default off) ────────────────────────────────────
# VITE_FEATURE_VIRTUAL_TRY_ON=false
# VITE_FEATURE_AI_RECOMMENDATIONS=false
# VITE_FEATURE_LOYALTY=false
# VITE_FEATURE_WALLET=false
# VITE_FEATURE_GIFT_CARDS=false
# VITE_FEATURE_MULTI_LANGUAGE=false
# VITE_FEATURE_MULTI_CURRENCY=false
# VITE_FEATURE_PWA=false
