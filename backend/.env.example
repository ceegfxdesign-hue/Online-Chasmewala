# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/online-chasmewala

# ── CORS (comma-separated origins) ───────────────────────────────────────────
CLIENT_URL=http://localhost:5173

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_dev_access_secret_please_use_openssl_rand_hex_32
JWT_REFRESH_SECRET=change_me_dev_refresh_secret_please_use_openssl_rand_hex_32
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
BCRYPT_SALT_ROUNDS=10

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Providers (mock by default; swap for real integrations later) ────────────
UPLOAD_PROVIDER=mock
PAYMENT_PROVIDER=mock
OTP_PROVIDER=mock

# Seed credentials (development only)
SEED_ADMIN_EMAIL=admin@onlinechasmewala.com
SEED_ADMIN_PASSWORD=Admin@123

# Cloudinary (only needed when UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
